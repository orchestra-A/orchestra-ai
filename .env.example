# Neo4j Aura connection — copy these straight from the instance's
# downloaded credentials file. NOTE: on current Aura instances the
# USERNAME and DATABASE are the instance ID (e.g. 74a94ebe), NOT "neo4j".
NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
NEO4J_USERNAME=xxxxxxxx
NEO4J_PASSWORD=your_password
NEO4J_DATABASE=xxxxxxxx

# Gemini key used by search.py
GEMINI_API_KEY=your_gemini_key

# Internal API key — required header (X-API-Key) for protected endpoints:
# /blueprint, /assign, /clover, /onboarding, /graph
INTERNAL_API_KEY=your_internal_api_key

# PostgreSQL (Neon) connection — used by db.py
DATABASE_URL=postgresql://user:password@host/dbname

# GitHub personal access token — used by onboarding.py to avoid GitHub API rate limits
GITHUB_TOKEN=your_github_token
